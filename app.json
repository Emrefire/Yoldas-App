{
  "expo": {
    "name": "Yoldaş",
    "slug": "YoldasApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#193f33"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emre.yoldas",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yoldaş, namaz vakitlerini ve kıble yönünü doğru hesaplamak için konumuna ihtiyaç duyar."
      }
    },
    "android": {
      "package": "com.emre.yoldas",
      "versionCode": 2,
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Yoldaş, namaz vakitlerini ve kıble yönünü doğru hesaplamak için konumuna ihtiyaç duyar."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#193f33",
          "sounds": [
            "./assets/sounds/ney.mp3",
            "./assets/sounds/kuscivilti.mp3",
            "./assets/sounds/ruzgarcan.mp3",
            "./assets/sounds/thunderbowl.mp3",
            "./assets/sounds/arabicsounds.mp3"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "2.0.21",
            "usesCleartextTraffic": false,
            "enableMultidex": true
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7784699073373527~9333732677"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2ddba26e-bbc7-40d2-a330-ff3a618f0f26"
      }
    }
  }
}
